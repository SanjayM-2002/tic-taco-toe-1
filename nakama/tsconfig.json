{
  "compilerOptions": {
    "target": "es5",
    "module": "es2015",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "declaration": true,
    "declarationDir": "./build",
    "outDir": "./build",
    "sourceMap": false,
    "typeRoots": ["./node_modules"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
